AP_step();

if (global.hp[1] > global.maxhp[1])
    global.hp[1] = global.maxhp[1];

if (global.hp[2] > global.maxhp[2])
    global.hp[2] = global.maxhp[2];

if (global.hp[3] > global.maxhp[3])
    global.hp[3] = global.maxhp[3];

if (global.hp[4] > global.maxhp[4])
    global.hp[4] = global.maxhp[4];
